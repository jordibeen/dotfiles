# font 
font-family = Cousine
font-size = 16
font-thicken = false

# theme
theme = dark:Catppuccin Mocha,light:Catppuccin Latte
fullscreen = true
window-decoration = none
window-padding-x = 8
window-padding-y = 8

# cursor
cursor-color = #FF5F1F
custom-shader = shaders/cursor_blaze.glsl
custom-shader-animation = true

# misc
mouse-hide-while-typing = true
macos-icon = glass
confirm-close-surface = false
